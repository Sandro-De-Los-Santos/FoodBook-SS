<Page x:Class="FoodBook_SS.Desktop.Views.Propietario.MesasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Gestión de Mesas" Background="{StaticResource BrBgDeep}">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de Mesas -->
        <Grid Grid.Column="0" Margin="0,0,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🪑 Gestión de Mesas" Style="{StaticResource H1}" Margin="0,0,0,24"/>

            <Border Grid.Row="1" Style="{StaticResource Card}">
                <DataGrid ItemsSource="{Binding Mesas}" AutoGenerateColumns="False" 
                          Background="Transparent" BorderThickness="0" CanUserAddRows="False" IsReadOnly="True"
                          RowBackground="Transparent" GridLinesVisibility="None" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nº Mesa" Binding="{Binding NumeroMesa}" Width="100" />
                        <DataGridTextColumn Header="Capacidad" Binding="{Binding Capacidad, StringFormat='{}{0} pers.'}" Width="100" />
                        <DataGridTextColumn Header="Ubicación" Binding="{Binding Ubicacion}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- Formulario Nueva Mesa -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel Margin="20">
                <TextBlock Text="➕ Añadir Nueva Mesa" Style="{StaticResource H2}" Margin="0,0,0,20"/>
                
                <TextBlock Text="Número de Mesa" Style="{StaticResource Body}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding NuevoNumero, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkInput}" Margin="0,0,0,16"/>

                <TextBlock Text="Capacidad (Personas)" Style="{StaticResource Body}" Margin="0,0,0,8"/>
                <Slider Value="{Binding NuevaCapacidad}" Minimum="1" Maximum="20" HorizontalAlignment="Left" Width="200" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding NuevaCapacidad, StringFormat='{}{0} personas'}" Margin="0,0,0,16" Foreground="{StaticResource BrAccent}" FontWeight="Bold"/>

                <TextBlock Text="Ubicación (Ej: Terraza, Ventana)" Style="{StaticResource Body}" Margin="0,0,0,8"/>
                <TextBox Text="{Binding NuevaUbicacion, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkInput}" Margin="0,0,0,24"/>

                <Button Content="Registrar Mesa" Command="{Binding AddCommand}" Style="{StaticResource BtnPrimary}" Padding="15" Height="Auto"/>

                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource BrSuccess}" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
