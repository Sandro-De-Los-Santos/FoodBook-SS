<Page x:Class="FoodBook_SS.Desktop.Views.Propietario.MetricasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Métricas" Background="{StaticResource BrBgDeep}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📊 Dashboard Administrativo" Style="{StaticResource H1}" Margin="0,0,0,24"/>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,30">
            <!-- Ingresos -->
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <Grid Margin="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Total de Ingresos" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalIngresos, StringFormat='RD$ {0:N2}'}" Foreground="{StaticResource BrAccent}" FontSize="24" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Text="Últimos 30 días" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                    <TextBlock Text="💰" FontSize="32" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3"/>
                </Grid>
            </Border>

            <!-- Órdenes -->
            <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                <Grid Margin="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Órdenes Totales" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalOrdenes}" Foreground="{StaticResource BrAccent}" FontSize="24" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Text="Operaciones activas" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                    <TextBlock Text="🧾" FontSize="32" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3"/>
                </Grid>
            </Border>

            <!-- Calificación -->
            <Border Style="{StaticResource Card}" Margin="6,0,6,0">
                <Grid Margin="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Calificación" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding CalificacionPromedio, StringFormat='{}{0:0.0} ⭐'}" Foreground="{StaticResource BrAccent}" FontSize="24" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Text="Feedback clientes" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                    <TextBlock Text="⭐" FontSize="32" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3"/>
                </Grid>
            </Border>

            <!-- Reservas Hoy -->
            <Border Style="{StaticResource Card}" Margin="12,0,0,0">
                <Grid Margin="12">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Reservas de Hoy" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding ReservasHoy}" Foreground="{StaticResource BrAccent}" FontSize="24" FontWeight="Bold" Margin="0,4"/>
                        <TextBlock Text="Programadas para hoy" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                    <TextBlock Text="📅" FontSize="32" HorizontalAlignment="Right" VerticalAlignment="Top" Opacity="0.3"/>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Top Products Section -->
        <Grid Grid.Row="2">
            <Border Style="{StaticResource Card}">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="🏆 Top 10 Productos Más Pedidos" Style="{StaticResource H2}" Margin="0,0,0,16"/>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding TopProductos}" AutoGenerateColumns="False" 
                              Background="Transparent" BorderThickness="0" CanUserAddRows="False" IsReadOnly="True"
                              RowBackground="Transparent" GridLinesVisibility="None" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Producto" Binding="{Binding NombreProducto}" Width="*" />
                            <DataGridTextColumn Header="Vendidos" Binding="{Binding TotalVendido}" Width="Auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{StaticResource BrAccent}"/>
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="20,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
