<Page x:Class="FoodBook_SS.Desktop.Views.Propietario.ResenasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Reseñas de Clientes" Background="{StaticResource BrBgDeep}">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de Reseñas -->
        <Grid Grid.Column="0" Margin="0,0,30,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⭐ Reseñas de Clientes" Style="{StaticResource H1}" Margin="0,0,0,24"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Resenas}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16" Padding="20">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding NombreCliente}" FontWeight="Bold" Foreground="{StaticResource BrAccent}" FontSize="16"/>
                                            <TextBlock Text=" — " Opacity="0.5" Foreground="{StaticResource BrTextDim}"/>
                                            <TextBlock Text="{Binding CreadoEn, StringFormat='{}{0:dd/MM/yyyy}'}" Foreground="{StaticResource BrTextDim}" Opacity="0.8" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Calificacion}" FontWeight="Bold" Foreground="Gold" FontSize="18"/>
                                            <TextBlock Text=" ⭐" Foreground="Gold" FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    
                                    <TextBlock Text="{Binding Comentario}" Foreground="{StaticResource BrText}" TextWrapping="Wrap" LineHeight="20" FontStyle="Italic" Margin="0,0,0,15"/>

                                    <Border Background="#1a202c" CornerRadius="8" Padding="15" Visibility="{Binding Respuesta, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverted}">
                                        <StackPanel>
                                            <TextBlock Text="Tu Respuesta:" FontWeight="Bold" Foreground="{StaticResource BrAccent}" FontSize="12" Margin="0,0,0,5"/>
                                            <TextBlock Text="{Binding Respuesta}" Foreground="{StaticResource BrText}" TextWrapping="Wrap" Opacity="0.9"/>
                                        </StackPanel>
                                    </Border>

                                    <Button Content="Responder" HorizontalAlignment="Right" Margin="0,10,0,0" 
                                            Visibility="{Binding Respuesta, Converter={StaticResource NullToVisibilityConverter}}"
                                            Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Panel de Respuesta -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top" Visibility="{Binding Selected, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverted}">
            <StackPanel Margin="20">
                <TextBlock Text="💬 Responder Comentario" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Selected.NombreCliente, StringFormat='Respondiendo a {0}'}" Style="{StaticResource Body}" Opacity="0.6" Margin="0,0,0,20"/>

                <TextBox Text="{Binding RespuestaText, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource DarkInput}"
                         AcceptsReturn="True" Height="150" VerticalContentAlignment="Top" Padding="10"
                         TextWrapping="Wrap" Margin="0,0,0,20"/>

                <Button Content="Enviar Respuesta" Command="{Binding ResponderCommand}" Style="{StaticResource BtnPrimary}" Padding="15" Height="Auto"/>
                
                <Button Content="Cancelar" Margin="0,10,0,0" Background="Transparent" BorderThickness="0" Foreground="Gray"
                        Command="{Binding DataContext.CancelCommand, RelativeSource={RelativeSource AncestorType=Page}}"/>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrAccent}" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,10,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
