<Window x:Class="FoodBook_SS.Desktop.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FoodBook SS — Registro" Width="420" Height="620"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{StaticResource BrBgDeep}">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1A2744" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" Margin="48,24">
                <TextBlock Text="🍽️ FoodBook SS" FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource BrAccent}" HorizontalAlignment="Center"
                           FontFamily="Segoe UI" Margin="0,0,0,6"/>
                <TextBlock Text="Crea tu cuenta" Style="{StaticResource Body}"
                           HorizontalAlignment="Center" Margin="0,0,0,28"/>

                <Border Style="{StaticResource Card}" Padding="28">
                    <StackPanel>
                        <TextBlock Text="Registro" Style="{StaticResource H2}" Margin="0,0,0,18"/>

                        <TextBlock Text="Nombre completo" Style="{StaticResource FormLabel}"/>
                        <TextBox   Style="{StaticResource DarkInput}" Margin="0,0,0,12"
                                   Text="{Binding Nombre, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Correo electrónico" Style="{StaticResource FormLabel}"/>
                        <TextBox   Style="{StaticResource DarkInput}" Margin="0,0,0,12"
                                   Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Contraseña" Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="PwdPass" Style="{StaticResource DarkPassword}"
                                     Margin="0,0,0,12" PasswordChanged="PwdPass_Changed"/>

                        <TextBlock Text="Confirmar contraseña" Style="{StaticResource FormLabel}"/>
                        <PasswordBox x:Name="PwdConfirm" Style="{StaticResource DarkPassword}"
                                     Margin="0,0,0,12" PasswordChanged="PwdConfirm_Changed"/>

                        <TextBlock Text="Tipo de cuenta" Style="{StaticResource FormLabel}"/>
                        <ComboBox  Style="{StaticResource DarkCombo}"
                                   ItemsSource="{Binding Roles}"
                                   SelectedItem="{Binding Rol}"
                                   Margin="0,0,0,18"/>

                        <!-- Mensajes -->
                        <Border Background="#3B1515" CornerRadius="6" Padding="10,7" Margin="0,0,0,10"
                                Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}" FontSize="12"/>
                        </Border>
                        <Border Background="#1A3B26" CornerRadius="6" Padding="10,7" Margin="0,0,0,10"
                                Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource BrSuccess}" FontSize="12"/>
                        </Border>

                        <Button Content="Crear cuenta" Style="{StaticResource BtnPrimary}"
                                Command="{Binding RegisterCommand}" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
