<Page x:Class="FoodBook_SS.Desktop.Views.Admin.AdminDashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Panel de Administración" Background="{StaticResource BrBgDeep}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,28">
            <TextBlock Text="🛠️ Administración Global" Style="{StaticResource H1}"/>
            <TextBlock Text="Supervisión completa de la plataforma FoodBook SS"
                       Foreground="{StaticResource BrTextDim}" FontSize="13" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- KPI Cards -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">
            <!-- Usuarios -->
            <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                <Grid Margin="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Usuarios Registrados" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalUsuarios}" Foreground="{StaticResource BrAccent}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding UsuariosActivos, StringFormat='{}{0} activos'}"
                                   FontSize="11" Foreground="#22C55E"/>
                    </StackPanel>
                    <TextBlock Text="👥" FontSize="36" HorizontalAlignment="Right"
                               VerticalAlignment="Top" Opacity="0.25"/>
                </Grid>
            </Border>

            <!-- Restaurantes -->
            <Border Style="{StaticResource Card}" Margin="5,0,5,0">
                <Grid Margin="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Restaurantes" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalRestaurantes}" Foreground="{StaticResource BrAccent}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding RestaurantesActivos, StringFormat='{}{0} aprobados'}"
                                   FontSize="11" Foreground="#22C55E"/>
                    </StackPanel>
                    <TextBlock Text="🏢" FontSize="36" HorizontalAlignment="Right"
                               VerticalAlignment="Top" Opacity="0.25"/>
                </Grid>
            </Border>

            <!-- Reseñas -->
            <Border Style="{StaticResource Card}" Margin="5,0,5,0">
                <Grid Margin="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Reseñas" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding TotalResenas}" Foreground="{StaticResource BrAccent}"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding ResenasOcultas, StringFormat='{}{0} ocultas'}"
                                   FontSize="11" Foreground="#EAB308"/>
                    </StackPanel>
                    <TextBlock Text="⭐" FontSize="36" HorizontalAlignment="Right"
                               VerticalAlignment="Top" Opacity="0.25"/>
                </Grid>
            </Border>

            <!-- Sin respuesta -->
            <Border Style="{StaticResource Card}" Margin="10,0,0,0">
                <Grid Margin="16">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Sin Respuesta" Style="{StaticResource Body}" Opacity="0.7"/>
                        <TextBlock Text="{Binding ResenasPendienteRespuesta}" Foreground="#EF4444"
                                   FontSize="32" FontWeight="Bold" Margin="0,4,0,2"/>
                        <TextBlock Text="reseñas por gestionar" FontSize="11" Foreground="{StaticResource BrTextDim}"/>
                    </StackPanel>
                    <TextBlock Text="💬" FontSize="36" HorizontalAlignment="Right"
                               VerticalAlignment="Top" Opacity="0.25"/>
                </Grid>
            </Border>
        </UniformGrid>

        <!-- Módulos (acceso rápido visual) -->
        <TextBlock Grid.Row="2" Text="⚡ Acceso Rápido" Style="{StaticResource H2}" Margin="0,0,0,16"/>

        <UniformGrid Grid.Row="3" Columns="4">
            <Border Style="{StaticResource Card}" Margin="0,0,10,0" Cursor="Hand" MouseLeftButtonUp="Modulo_Click" Tag="Usuarios">
                <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="👥" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Usuarios" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrText}" FontSize="15"/>
                    <TextBlock Text="Gestionar cuentas y accesos" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrTextDim}" FontSize="11" Margin="0,5,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="5,0,5,0" Cursor="Hand" MouseLeftButtonUp="Modulo_Click" Tag="Restaurantes">
                <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🏢" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Restaurantes" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrText}" FontSize="15"/>
                    <TextBlock Text="Aprobar y supervisar locales" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrTextDim}" FontSize="11" Margin="0,5,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="5,0,5,0" Cursor="Hand" MouseLeftButtonUp="Modulo_Click" Tag="Moderacion">
                <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🛡️" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Moderación" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrText}" FontSize="15"/>
                    <TextBlock Text="Control global de reseñas" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrTextDim}" FontSize="11" Margin="0,5,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonUp="Modulo_Click" Tag="Auditoria">
                <StackPanel Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="📜" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Auditoría" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrText}" FontSize="15"/>
                    <TextBlock Text="Historial de transacciones" HorizontalAlignment="Center"
                               Foreground="{StaticResource BrTextDim}" FontSize="11" Margin="0,5,0,0"
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</Page>
