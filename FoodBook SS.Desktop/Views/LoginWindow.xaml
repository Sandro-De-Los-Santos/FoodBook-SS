<Window x:Class="FoodBook_SS.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FoodBook_SS.Desktop.ViewModels"
        Title="FoodBook SS — Iniciar Sesión"
        Width="420" Height="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{StaticResource BrBgDeep}">

    <Grid>
        <!-- Fondo degradado sutil -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0F172A" Offset="0"/>
                <GradientStop Color="#1A2744" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center" Margin="48,0">

            <!-- Logo + Titulo -->
            <TextBlock Text="🍽️ FoodBook SS"
                       FontSize="28" FontWeight="Bold" FontFamily="Segoe UI"
                       Foreground="{StaticResource BrAccent}"
                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Plataforma de Reservas y Órdenes"
                       Style="{StaticResource Body}"
                       HorizontalAlignment="Center" Margin="0,0,0,36"/>

            <!-- Card de Login -->
            <Border Style="{StaticResource Card}" Padding="32,28">
                <StackPanel>
                    <TextBlock Text="Iniciar Sesión" Style="{StaticResource H2}" Margin="0,0,0,20"/>

                    <!-- Email -->
                    <TextBlock Text="Correo electrónico" Style="{StaticResource FormLabel}"/>
                    <TextBox x:Name="TxtEmail"
                             Style="{StaticResource DarkInput}"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,14"/>

                    <!-- Password -->
                    <TextBlock Text="Contraseña" Style="{StaticResource FormLabel}"/>
                    <PasswordBox x:Name="PwdPassword"
                                 Style="{StaticResource DarkPassword}"
                                 Margin="0,0,0,20"
                                 PasswordChanged="PwdPassword_PasswordChanged"/>

                    <!-- Error -->
                    <Border Background="#3B1515" CornerRadius="6" Padding="10,7"
                            Margin="0,0,0,14"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}" FontSize="12"/>
                    </Border>

                    <!-- Botón Login -->
                    <Button Content="Iniciar sesión"
                            Style="{StaticResource BtnPrimary}"
                            Command="{Binding LoginCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,12"/>

                    <!-- Registro -->
                    <Button Content="¿No tienes cuenta? Regístrate"
                            Style="{StaticResource BtnSecondary}"
                            Command="{Binding RegisterCommand}"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <!-- Cargando -->
            <TextBlock Text="⏳ Iniciando sesión..."
                       Style="{StaticResource Body}"
                       HorizontalAlignment="Center" Margin="0,14,0,0"
                       Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
        </StackPanel>
    </Grid>
</Window>
