<Page x:Class="FoodBook_SS.Desktop.Views.Cliente.NuevaOrdenPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:FoodBook_SS.Desktop.Converters"
      Title="Añadir Orden" Background="{StaticResource BrBgDeep}">
    
    <Page.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Page.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="← Volver a Mis Reservas" Style="{StaticResource BtnSecondary}" 
                    Command="{Binding CancelarCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"/>
            <TextBlock Text="🍽️ Añadir Orden" Style="{StaticResource H1}"/>
            <TextBlock Text="Selecciona los platillos para acelerar el proceso cuando llegues al restaurante." 
                       Style="{StaticResource Body}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Errores -->
        <Border Grid.Row="1" Background="#3B1515" CornerRadius="6" Padding="12,8" Margin="0,0,0,16"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}"/>
        </Border>

        <!-- Contenido principal -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- Menú -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                <Grid>
                    <TextBlock Text="Cargando menú..." Style="{StaticResource Body}" 
                               Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}" HorizontalAlignment="Center" Margin="0,20"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Productos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BrBorder}" BorderThickness="0,0,0,1" Padding="0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                                <TextBlock Text="{Binding Nombre}" Style="{StaticResource H2}" FontSize="15" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Descripcion}" Style="{StaticResource Body}" Foreground="{StaticResource BrTextDim}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{Binding Precio, StringFormat='RD${0:N2}'}" 
                                                       Style="{StaticResource H2}" Foreground="{StaticResource BrAccent}" 
                                                       VerticalAlignment="Center" Margin="0,0,20,0"/>

                                            <!-- Selector de cantidad -->
                                            <Border Grid.Column="2" Background="#0F172A" CornerRadius="8" Padding="4" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="-" Command="{Binding RemoveCommand}" Width="32" Height="32" 
                                                            Background="Transparent" Foreground="White" BorderThickness="0" FontSize="18" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Cantidad}" Foreground="White" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold" Width="30" TextAlignment="Center"/>
                                                    <Button Content="+" Command="{Binding AddCommand}" Width="32" Height="32" 
                                                            Background="Transparent" Foreground="{StaticResource BrAccent}" BorderThickness="0" FontSize="18" FontWeight="Bold"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Checkout -->
            <Border Grid.Column="2" Style="{StaticResource Card}" VerticalAlignment="Top" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resumen de Orden" Style="{StaticResource H2}" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Total estimado" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalOrd, StringFormat='RD${0:N2}'}" Foreground="{StaticResource BrAccent}" 
                               FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Notas para el restaurante" Style="{StaticResource FormLabel}"/>
                    <TextBox Text="{Binding Notas}" Style="{StaticResource DarkInput}" Height="80" 
                             AcceptsReturn="True" TextWrapping="Wrap" Margin="0,0,0,24"/>

                    <Button Content="✅ Confirmar Orden" Style="{StaticResource BtnPrimary}"
                            Command="{Binding ConfirmarCommand}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
