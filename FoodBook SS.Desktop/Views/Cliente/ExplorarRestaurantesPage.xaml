<Page x:Class="FoodBook_SS.Desktop.Views.Cliente.ExplorarRestaurantesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Explorar Restaurantes" Background="{StaticResource BrBgDeep}">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabecera -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="🍽️ Explorar Restaurantes" Style="{StaticResource H1}"/>
            <TextBlock Text="Encuentra tu próximo lugar favorito para comer."
                       Style="{StaticResource Body}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Filtros (Dashboard Header) -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding FiltroNombre, UpdateSourceTrigger=PropertyChanged}" 
                         Tag="Buscar por nombre..." Style="{StaticResource DarkInput}"/>
                         
                <TextBox Grid.Column="2" Text="{Binding FiltroCiudad, UpdateSourceTrigger=PropertyChanged}" 
                         Tag="Ciudad" Style="{StaticResource DarkInput}"/>
                         
                <TextBox Grid.Column="4" Text="{Binding FiltroTipoCocina, UpdateSourceTrigger=PropertyChanged}" 
                         Tag="Tipo de cocina (ej. Italiana)" Style="{StaticResource DarkInput}"/>

                <Button Grid.Column="6" Content="🔍 Buscar" Style="{StaticResource BtnPrimary}" 
                        Command="{Binding SearchCommand}" Padding="15,0"/>
                
                <Button Grid.Column="8" Content="✖ Limpiar" Style="{StaticResource BtnSecondary}" 
                        Command="{Binding ClearFiltersCommand}" Padding="10,0"/>
            </Grid>
        </Border>

        <!-- Area de carga o Errores -->
        <TextBlock Grid.Row="2" Text="Buscando restaurantes..." Foreground="{StaticResource BrTextDim}"
                   HorizontalAlignment="Center" Margin="0,40,0,0" x:Name="Loader"
                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>
                   
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}"
                   HorizontalAlignment="Center" Margin="0,40,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>

        <!-- Cuadrícula de Resultados -->
        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Restaurantes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" Margin="0,-10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Tarjeta de Restaurante (replicando la web) -->
                        <Border Style="{StaticResource Card}" Width="310" Margin="0,10,15,10" Padding="16">
                            <StackPanel>
                                <!-- Nombre y Detalles -->
                                <TextBlock Text="{Binding Nombre}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrText}" TextWrapping="Wrap"/>
                                <TextBlock Foreground="{StaticResource BrTextDim}" FontSize="12" Margin="0,2,0,10">
                                    <Run Text="{Binding TipoCocina}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Ciudad}"/>
                                </TextBlock>
                                
                                <TextBlock Text="{Binding Direccion}" Foreground="{StaticResource BrTextDim}" 
                                           FontSize="13" TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                           
                                <!-- Ratings -->
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,16">
                                    <Border Background="#422006" CornerRadius="6" Padding="6,2">
                                        <TextBlock Foreground="#FACC15" FontSize="11" FontWeight="Bold">
                                            <Run Text="⭐ "/>
                                            <Run Text="{Binding CalificacionProm, StringFormat=N1}"/>
                                            <Run Text=" ("/>
                                            <Run Text="{Binding TotalResenas}"/>
                                            <Run Text=" reseñas)"/>
                                        </TextBlock>
                                    </Border>
                                    <Border Background="#334155" CornerRadius="6" Padding="6,2" Margin="6,0,0,0"
                                            Visibility="{Binding RangoPrecio, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                        <TextBlock Text="{Binding RangoPrecio}" Foreground="{StaticResource BrText}" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </StackPanel>

                                <Separator Background="{StaticResource BrBorder}" Margin="-16,0,-16,12"/>

                                <!-- Acciones -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Reservar Mesa" Style="{StaticResource BtnPrimary}"
                                            CommandParameter="{Binding}" Click="BtnReservar_Click" Padding="12,5" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
