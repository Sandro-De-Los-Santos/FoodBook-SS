<Page x:Class="FoodBook_SS.Desktop.Views.Cliente.PagarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:FoodBook_SS.Desktop.Converters"
      Title="Pagos" Background="{StaticResource BrBgDeep}">
    <Page.Resources>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Page.Resources>
    <Grid Margin="32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- Lista de órdenes pendientes -->
        <StackPanel Grid.Column="0" Margin="0,0,24,0">
            <TextBlock Text="💳 Pagar Orden" Style="{StaticResource H1}" Margin="0,0,0,20"/>
            <TextBlock Text="Selecciona una orden pendiente:" Style="{StaticResource Body}" Margin="0,0,0,12"/>
            <ListBox x:Name="ListOrdenes" Background="Transparent" BorderThickness="0"
                     ItemsSource="{Binding OrdenesPendientes}"
                     SelectedItem="{Binding OrdenSelected}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,8" Padding="16,12" Width="420">
                            <StackPanel>
                                <TextBlock Text="{Binding Id, StringFormat='Orden #{0}'}"
                                           Foreground="{StaticResource BrText}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Total, StringFormat='Total: RD${0:N2}'}"
                                           Foreground="{StaticResource BrAccent}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>

        <!-- Panel de pago -->
        <Border Grid.Column="1" Style="{StaticResource Card}" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Resumen de Pago" Style="{StaticResource H2}" Margin="0,0,0,20"/>

                <TextBlock Text="Orden Seleccionada" Style="{StaticResource FormLabel}"/>
                <TextBlock Text="{Binding OrdenSelected.Id, StringFormat='Orden #{0}'}"
                           Foreground="{StaticResource BrText}" FontSize="14" Margin="0,0,0,14"/>

                <TextBlock Text="Monto a Pagar" Style="{StaticResource FormLabel}"/>
                <TextBlock Text="{Binding Monto, StringFormat='RD${0:N2}'}"
                           Foreground="{StaticResource BrAccent}" FontSize="22" FontWeight="Bold" Margin="0,0,0,18"/>

                <TextBlock Text="Método de Pago" Style="{StaticResource FormLabel}"/>
                <ComboBox  Style="{StaticResource DarkCombo}" Margin="0,0,0,20"
                           ItemsSource="{Binding Metodos}"
                           SelectedItem="{Binding MetodoPago}"/>

                <!-- Mensajes -->
                <Border Background="#3B1515" CornerRadius="6" Padding="10,7" Margin="0,0,0,12"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}" FontSize="12"/>
                </Border>
                <Border Background="#1A3B26" CornerRadius="6" Padding="10,7" Margin="0,0,0,12"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource StrVis}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource BrSuccess}" FontSize="12"/>
                </Border>

                <Button Content="💳  Procesar Pago" Style="{StaticResource BtnPrimary}"
                        Command="{Binding PagarCommand}" HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
