<Page x:Class="FoodBook_SS.Desktop.Views.Cliente.MisReservasPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:FoodBook_SS.Desktop.Converters"
      Title="Mis Reservas" Background="{StaticResource BrBgDeep}">

    <Page.Resources>
        <conv:EstadoColorConverter x:Key="EstadoColor"/>
        <conv:StringToVisibilityConverter x:Key="StrVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Page.Resources>

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📅 Mis Reservas" Style="{StaticResource H1}"/>
            <Button Content="↻ Actualizar" Style="{StaticResource BtnSecondary}"
                    Command="{Binding LoadCommand}" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Mensajes -->
        <Border Grid.Row="1" Background="#3B1515" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource BrDanger}"/>
        </Border>

        <!-- Lista de reservas -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Loading -->
                <TextBlock Text="⏳ Cargando reservas..."
                           Style="{StaticResource Body}" Margin="0,20"
                           HorizontalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>

                <!-- Items -->
                <ListBox ItemsSource="{Binding Reservas}" SelectedItem="{Binding Selected}" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding NombreRestaurante}" Style="{StaticResource H2}" FontSize="15"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="📅 " Style="{StaticResource Body}"/>
                                                <TextBlock Text="{Binding FechaReserva}" Style="{StaticResource Body}"/>
                                                <TextBlock Text="  ⏰ " Style="{StaticResource Body}"/>
                                                <TextBlock Text="{Binding HoraReserva}" Style="{StaticResource Body}"/>
                                                <TextBlock Text="  👥 " Style="{StaticResource Body}"/>
                                                <TextBlock Text="{Binding NumeroPersonas}" Style="{StaticResource Body}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CodigoConfirmacion}"
                                                       Foreground="{StaticResource BrTextDim}"
                                                       FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <!-- Badge de estado -->
                                        <Border Grid.Column="1" CornerRadius="20" Padding="12,5" VerticalAlignment="Top">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding Estado,
                                                    Converter={StaticResource EstadoColor}}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Estado}" Foreground="White"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    <!-- Acciones -->
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="🍽️ Añadir Orden" Style="{StaticResource BtnSecondary}"
                                                Command="{Binding DataContext.AnadirOrdenCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                IsHitTestVisible="True" Margin="0,0,10,0"/>

                                        <Button Content="❌ Cancelar Reserva" Style="{StaticResource BtnDanger}"
                                                Command="{Binding DataContext.CancelarCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                IsHitTestVisible="True"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
