<Page x:Class="FoodBook_SS.Desktop.Views.Cliente.MisOrdenesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:FoodBook_SS.Desktop.Converters"
      Title="Mis Órdenes" Background="{StaticResource BrBgDeep}">
    <Page.Resources>
        <conv:EstadoColorConverter x:Key="EstadoColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Page.Resources>
    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="🧾 Mis Órdenes" Style="{StaticResource H1}"/>
            <Button Content="↻ Actualizar" Style="{StaticResource BtnSecondary}"
                    Command="{Binding LoadCommand}" Margin="16,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Ordenes}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Id, StringFormat='Orden #{0}'}"
                                               Style="{StaticResource H2}" FontSize="15"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                        <TextBlock Text="Reserva #" Style="{StaticResource Body}"/>
                                        <TextBlock Text="{Binding ReservaId}" Style="{StaticResource Body}"/>
                                        <TextBlock Text="   Total: RD$" Style="{StaticResource Body}"/>
                                        <TextBlock Text="{Binding Total, StringFormat='{}{0:N2}'}"
                                                   Foreground="{StaticResource BrAccent}" FontWeight="Bold"/>
                                    </StackPanel>
                                    <!-- Items de la orden -->
                                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="{StaticResource BrTextDim}" FontSize="12"
                                                           Text="{Binding NombreProducto, StringFormat='• {0}'}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <Border Grid.Column="1" CornerRadius="20" Padding="12,5" VerticalAlignment="Top">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Estado, Converter={StaticResource EstadoColor}}"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding Estado}" Foreground="White"
                                               FontSize="12" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
