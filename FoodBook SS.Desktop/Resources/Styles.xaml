<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:s="clr-namespace:FoodBook_SS.Desktop.Converters">


    <s:StringToVisibilityConverter  x:Key="StringToVisibility"/>
    <s:BoolToVisibilityConverter    x:Key="BoolToVisibility"/>
    <s:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <s:EstadoColorConverter         x:Key="EstadoColor"/>
    <s:NullToVisibilityConverter    x:Key="NullToVisibilityConverter"/>


    <Color x:Key="C_BgDeep">#0F172A</Color>
    <Color x:Key="C_BgCard">#1E293B</Color>
    <Color x:Key="C_BgSidebar">#0B1120</Color>
    <Color x:Key="C_Accent">#F97316</Color>
    <Color x:Key="C_AccentHover">#EA6C0A</Color>
    <Color x:Key="C_TextPrimary">#F1F5F9</Color>
    <Color x:Key="C_TextDim">#94A3B8</Color>
    <Color x:Key="C_Border">#2D3748</Color>
    <Color x:Key="C_Success">#22C55E</Color>
    <Color x:Key="C_Warning">#EAB308</Color>
    <Color x:Key="C_Danger">#EF4444</Color>

    <SolidColorBrush x:Key="BrBgDeep"     Color="{StaticResource C_BgDeep}"/>
    <SolidColorBrush x:Key="BrBgCard"     Color="{StaticResource C_BgCard}"/>
    <SolidColorBrush x:Key="BrBgSidebar"  Color="{StaticResource C_BgSidebar}"/>
    <SolidColorBrush x:Key="BrAccent"     Color="{StaticResource C_Accent}"/>
    <SolidColorBrush x:Key="BrAccentHov"  Color="{StaticResource C_AccentHover}"/>
    <SolidColorBrush x:Key="BrText"       Color="{StaticResource C_TextPrimary}"/>
    <SolidColorBrush x:Key="BrTextDim"    Color="{StaticResource C_TextDim}"/>
    <SolidColorBrush x:Key="BrBorder"     Color="{StaticResource C_Border}"/>
    <SolidColorBrush x:Key="BrSuccess"    Color="{StaticResource C_Success}"/>
    <SolidColorBrush x:Key="BrWarning"    Color="{StaticResource C_Warning}"/>
    <SolidColorBrush x:Key="BrDanger"     Color="{StaticResource C_Danger}"/>


    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource BrText}"/>
        <Setter Property="FontSize"    Value="24"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource BrText}"/>
        <Setter Property="FontSize"    Value="18"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
    </Style>
    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource BrTextDim}"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
    </Style>


    <Style x:Key="BtnPrimary" TargetType="Button">
        <Setter Property="Background"  Value="{StaticResource BrAccent}"/>
        <Setter Property="Foreground"  Value="White"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="Padding"     Value="18,9"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrAccentHov}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="BtnSecondary" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="Padding"         Value="14,7"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#1E293B"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background" Value="{StaticResource BrDanger}"/>
    </Style>


    <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
        <Setter Property="Background" Value="{StaticResource BrSuccess}"/>
    </Style>


    <Style x:Key="DarkInput" TargetType="TextBox">
        <Setter Property="Background"      Value="#0F172A"/>
        <Setter Property="Foreground"      Value="{StaticResource BrText}"/>
        <Setter Property="CaretBrush"      Value="{StaticResource BrAccent}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="DarkPassword" TargetType="PasswordBox">
        <Setter Property="Background"      Value="#0F172A"/>
        <Setter Property="Foreground"      Value="{StaticResource BrText}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Padding"         Value="10,8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="2"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource BrAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource BrBgCard}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="12"/>
        <Setter Property="Padding"         Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="16" ShadowDepth="2"/>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="DarkCombo" TargetType="ComboBox">
        <Setter Property="Background"      Value="#0F172A"/>
        <Setter Property="Foreground"      Value="Black"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BrBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Padding"         Value="8,6"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Background"  Value="#1E293B"/>
                    <Setter Property="Foreground"  Value="{StaticResource BrText}"/>
                    <Setter Property="Padding"     Value="10,7"/>
                    <Setter Property="FontSize"    Value="13"/>
                    <Setter Property="FontFamily"  Value="Segoe UI"/>
                    <Style.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter Property="Background" Value="#F97316"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EA6C0A"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="NavItem" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource BrTextDim}"/>
        <Setter Property="FontSize"        Value="14"/>
        <Setter Property="FontFamily"      Value="Segoe UI"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="16,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border" Background="{TemplateBinding Background}"
                            CornerRadius="8" Margin="8,2"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                            <Setter Property="Foreground" Value="{StaticResource BrText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavItemActive" TargetType="Button" BasedOn="{StaticResource NavItem}">
        <Setter Property="Background"  Value="#1E293B"/>
        <Setter Property="Foreground"  Value="{StaticResource BrAccent}"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>


    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource BrBorder}"/>
        <Setter Property="Margin"     Value="0,8"/>
    </Style>

    <Style x:Key="FormLabel" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource BrTextDim}"/>
        <Setter Property="FontSize"    Value="12"/>
        <Setter Property="FontWeight"  Value="SemiBold"/>
        <Setter Property="Margin"      Value="0,0,0,4"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
    </Style>

</ResourceDictionary>
