@model FoodBook_SS.Application.Dtos.User.LoginDto
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = "_Layout";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-dark text-white text-center">
                <h4>🍽️ FoodBook SS</h4>
                <small>Inicia sesión en tu cuenta</small>
            </div>
            <div class="card-body">
                <form asp-controller="Account" asp-action="Login" method="post" id="loginForm" novalidate>
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" id="serverErrors"
                         style="display:@(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Correo electrónico</label>
                        <input asp-for="Email"
                               class="form-control @(ViewData.ModelState["Email"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               placeholder="correo@ejemplo.com"
                               autocomplete="email" />
                        <span asp-validation-for="Email" class="invalid-feedback d-block small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Contraseña</label>
                        <input asp-for="Password"
                               type="password"
                               class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")"
                               autocomplete="current-password" />
                        <span asp-validation-for="Password" class="invalid-feedback d-block small"></span>
                    </div>

                    <button type="submit" class="btn btn-dark w-100" id="btnLogin">
                        Ingresar
                    </button>
                </form>
            </div>
            <div class="card-footer text-center text-muted">
                ¿No tienes cuenta?
                <a asp-controller="Account" asp-action="Register">Regístrate aquí</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const $loginForm = $('#loginForm');

            if ($loginForm.length > 0) {
                $loginForm.on('submit', function (e) {
             
                    if ($(this).valid()) {
                        const btn = document.getElementById('btnLogin');
                        btn.disabled = true;
                        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Ingresando...';
                    }
                });
            }
        });
    </script>
}
  
          
