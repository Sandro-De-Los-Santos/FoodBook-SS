@model FoodBook_SS.Application.Dtos.Review.SaveReviewDto
@{
    ViewData["Title"] = "Calificar Experiencia";
    var orden       = ViewBag.Orden as FoodBook_SS.Domain.Entities.Order.Orden;
    var restaurante = (string)(ViewBag.Restaurante ?? "");
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-5">

        <div class="page-header">
            <h2>⭐ Calificar Experiencia</h2>
        </div>

        @* Info de la orden *@
        @if (orden != null)
        {
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between" style="font-size:.875rem;">
                        <span class="text-muted">Restaurante</span>
                        <strong>@restaurante</strong>
                    </div>
                    <div class="d-flex justify-content-between mt-1" style="font-size:.875rem;">
                        <span class="text-muted">Orden</span>
                        <code>#@orden.Id</code>
                    </div>
                    <div class="d-flex justify-content-between mt-1" style="font-size:.875rem;">
                        <span class="text-muted">Total pagado</span>
                        <strong style="color:var(--accent);">RD$ @orden.Total.ToString("N2")</strong>
                    </div>
                </div>
            </div>
        }

        <div class="card shadow-glow">
            <div class="card-header">Tu opinión nos importa</div>
            <div class="card-body p-4">

                <form asp-action="Crear" method="post" id="formResena">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <input asp-for="OrdenId"       type="hidden" />
                    <input asp-for="RestauranteId"  type="hidden" />

                    @* Selector de estrellas *@
                    <div class="mb-4 text-center">
                        <label class="form-label d-block mb-3">¿Cuántas estrellas le das?</label>

                        <div class="star-rating justify-content-center" id="starRating">
                            @for (byte i = 5; i >= 1; i--)
                            {
                                <input type="radio" name="Calificacion" id="star@(i)"
                                       value="@i" @(Model.Calificacion == i ? "checked" : "") />
                                <label for="star@(i)" title="@i estrella@(i > 1 ? "s" : "")"
                                       id="starLabel@(i)">★</label>
                            }
                        </div>

                        <div id="starTexto" class="mt-2 text-muted" style="font-size:.875rem; min-height:1.4rem;"></div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Comentario" class="form-label">Comentario</label>
                        <textarea asp-for="Comentario" class="form-control" rows="4"
                                  id="comentario"
                                  placeholder="Cuéntanos cómo fue tu experiencia. ¿Qué te gustó? ¿Qué mejorarías?"></textarea>
                        <span asp-validation-for="Comentario" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill" id="btnEnviarResena">
                            ⭐ Enviar Reseña
                        </button>
                        <a asp-controller="Orden" asp-action="Index"
                           class="btn btn-outline-secondary" id="btnCancelarResena">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>

        <p class="text-muted text-center mt-3" style="font-size:.78rem;">
            🔒 Solo puedes calificar órdenes completadas (Regla de Negocio RN-05)
        </p>

    </div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
    const textos = {
        1: '😞 Muy malo — No me gustó',
        2: '😐 Regular — Estuvo bien',
        3: '😊 Bueno — Lo recomendaría',
        4: '😃 Muy bueno — Excelente servicio',
        5: '🤩 Perfecto — ¡Superó mis expectativas!'
    };

    document.querySelectorAll('input[name="Calificacion"]').forEach(radio => {
        radio.addEventListener('change', function() {
            document.getElementById('starTexto').textContent = textos[parseInt(this.value)] || '';
        });
        
        if (radio.checked) {
            document.getElementById('starTexto').textContent = textos[parseInt(radio.value)] || '';
        }
    });

    document.getElementById('formResena').addEventListener('submit', function(e) {
        const checked = document.querySelector('input[name="Calificacion"]:checked');
        if (!checked) {
            e.preventDefault();
            document.getElementById('starTexto').textContent = '⚠️ Por favor selecciona una calificación.';
            document.getElementById('starTexto').style.color = 'var(--danger)';
        }
    });
</script>
}
