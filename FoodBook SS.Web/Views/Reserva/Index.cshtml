@model IEnumerable<FoodBook_SS.Domain.Entities.Reservation.Reserva>
@{
    ViewData["Title"] = "Mis Reservas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2> Mis Reservas</h2>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">No tienes reservas aún. <a asp-controller="Home" asp-action="Index">Busca un restaurante</a></div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Restaurante</th>
                    <th>Fecha</th>
                    <th>Hora</th>
                    <th>Personas</th>
                    <th>Mesa</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><code>@r.CodigoConfirmacion</code></td>
                        <td>@r.Restaurante?.Nombre</td>
                        <td>@r.FechaReserva.ToString("dd/MM/yyyy")</td>
                        <td>@r.HoraReserva.ToString("hh\\:mm")</td>
                        <td>@r.NumeroPersonas</td>
                        <td>@(r.Mesa?.NumeroMesa ?? "—")</td>
                        <td>
                            @{
                                var badge = r.Estado switch
                                {
                                    "Confirmada" => "success",
                                    "Pendiente" => "warning",
                                    "Cancelada" => "danger",
                                    "Completada" => "secondary",
                                    _ => "dark"
                                };
                            }
                            <span class="badge bg-@badge">@r.Estado</span>
                        </td>
                        <td>
                            @if (r.Estado is "Pendiente" or "Confirmada")
                            {
                                <form asp-action="Cancelar" method="post" class="d-inline"
                                      onsubmit="return confirm('¿Seguro que deseas cancelar esta reserva?')">
                                    @Html.AntiForgeryToken()
                                    <input name="id" type="hidden" value="@r.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancelar</button>
                                </form>
                                <a asp-controller="Orden" asp-action="Crear"
                                   asp-route-restauranteId="@r.RestauranteId"
                                   class="btn btn-sm btn-outline-success ms-1">Ordenar</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
