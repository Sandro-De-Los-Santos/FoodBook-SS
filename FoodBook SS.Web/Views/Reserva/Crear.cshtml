@model FoodBook_SS.Application.Dtos.Reservation.SaveReservationDto
@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0"> Nueva Reserva</h5>
            </div>
            <div class="card-body">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <input asp-for="RestauranteId" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="FechaReserva" class="form-label">Fecha</label>
                        <input asp-for="FechaReserva" type="date" class="form-control"
                               min="@DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="FechaReserva" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="HoraReserva" class="form-label">Hora</label>
                        <input asp-for="HoraReserva" type="time" class="form-control" />
                        <span asp-validation-for="HoraReserva" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NumeroPersonas" class="form-label">Número de personas</label>
                        <input asp-for="NumeroPersonas" type="number" min="1" max="20" class="form-control" />
                        <span asp-validation-for="NumeroPersonas" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="NotasEspeciales" class="form-label">
                            Notas especiales <small class="text-muted">(opcional)</small>
                        </label>
                        <textarea asp-for="NotasEspeciales" class="form-control" rows="2"
                                  placeholder="Alergias, celebraciones, etc."></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark">Crear Reserva</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
