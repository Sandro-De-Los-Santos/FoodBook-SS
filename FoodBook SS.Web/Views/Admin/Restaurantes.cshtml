@model IEnumerable<FoodBook_SS.Domain.Entities.Configuration.Restaurante>
@{
    ViewData["Title"] = "Gestión de Restaurantes";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2>🏢 Restaurantes en la plataforma</h2>
        <p class="text-dim">Supervisa y aprueba nuevos locales</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">← Volver</a>
</div>

<div class="card border-0 shadow-sm overflow-hidden" style="background: var(--card-bg);">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-darker">
                <tr>
                    <th class="ps-4">Restaurante</th>
                    <th>Ubicación</th>
                    <th>Tipo</th>
                    <th class="text-center">Calificación</th>
                    <th class="text-center">Estado</th>
                    <th class="text-end pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.OrderByDescending(x => x.Id))
                {
                    <tr>
                        <td class="ps-4">
                            <div class="font-bold">@r.Nombre</div>
                            <small class="text-dim">Dueño ID: #@r.PropietarioId</small>
                        </td>
                        <td>@r.Ciudad</td>
                        <td><span class="badge bg-secondary">@r.TipoCocina</span></td>
                        <td class="text-center">
                            <span class="text-warning">★</span> @r.CalificacionProm.ToString("0.0")
                            <small class="text-dim">(@r.TotalResenas)</small>
                        </td>
                        <td class="text-center">
                            @if (r.Activo) { <span class="badge bg-success">Aprobado</span> }
                            else { <span class="badge bg-warning text-dark">Suspendido / Pendiente</span> }
                        </td>
                        <td class="text-end pe-4">
                             <form asp-action="ToggleRestaurante" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input name="restauranteId" type="hidden" value="@r.Id" />
                                <input name="activo" type="hidden" value="@(!r.Activo ? "true" : "false")" />
                                <button type="submit" class="btn btn-sm @(r.Activo ? "btn-outline-warning" : "btn-outline-success")">
                                    @(r.Activo ? "⏸ Suspender" : "✅ Aprobar")
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
