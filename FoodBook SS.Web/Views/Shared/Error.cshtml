@model FoodBook_SS.Web.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center mt-5">
    <h1 class="display-1 text-danger">⚠️</h1>
    <h2>Ocurrió un error</h2>
    <p class="text-muted">
        @if (Model?.ShowRequestId == true)
        {
            <span>Request ID: <code>@Model.RequestId</code></span>
        }
    </p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-dark">Volver al inicio</a>
</div>
