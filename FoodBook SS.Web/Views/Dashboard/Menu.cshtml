@model FoodBook_SS.Web.Models.DashboardMenuViewModel
@{
    ViewData["Title"] = "Gestión de Menú";
    var categorias    = Model.Categorias.ToList();
    var productos     = Model.Productos.ToList();
    var restId        = (int)(ViewBag.RestauranteId ?? 0);
    var restaurantes  = ViewBag.Restaurantes as List<FoodBook_SS.Application.Dtos.Restaurant.RestaurantDto>
                        ?? new List<FoodBook_SS.Application.Dtos.Restaurant.RestaurantDto>();
}

<div class="page-header">
    <h2>🍴 Gestión de Menú</h2>
    @if (restId > 0)
    {
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalProducto" id="btnAgregarProducto">
            + Nuevo Producto
        </button>
    }
</div>

@* Selector restaurante *@
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <label class="form-label">Restaurante</label>
                <select name="restauranteId" class="form-select" onchange="this.form.submit()" id="selectorRestaurante">
                    @foreach (var r in restaurantes)
                    {
                        <option value="@r.Id" selected="@(restId == r.Id)">@r.Nombre</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

@if (restId == 0)
{
    <div class="alert alert-info">Selecciona un restaurante para gestionar su menú.</div>
}
else
{
    @* Tabs: Categorías | Productos *@
    <ul class="nav nav-tabs" id="menuTabs">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#tabCategorias" id="tabBtnCategorias">
                📂 Categorías (@categorias.Count)
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#tabProductos" id="tabBtnProductos">
                🍕 Productos (@productos.Count)
            </a>
        </li>
    </ul>

    <div class="tab-content">
        @* ── Tab Categorías ─────────────────────────────── *@
        <div class="tab-pane fade show active" id="tabCategorias">
            <div class="d-flex justify-content-end mb-3">
                <button class="btn btn-outline-primary btn-sm"
                        data-bs-toggle="modal" data-bs-target="#modalCategoria"
                        id="btnAgregarCategoria">
                    + Nueva Categoría
                </button>
            </div>
            @if (!categorias.Any())
            {
                <div class="alert alert-info">No hay categorías. Crea la primera.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaCategorias">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Orden</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in categorias)
                            {
                                <tr>
                                    <td><code>@c.Id</code></td>
                                    <td><strong>@c.Nombre</strong></td>
                                    <td class="text-muted">@(c.Descripcion ?? "—")</td>
                                    <td>@c.Orden</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @* ── Tab Productos ─────────────────────────────── *@
        <div class="tab-pane fade" id="tabProductos">
            @if (!productos.Any())
            {
                <div class="alert alert-info mt-3">No hay productos. Agrega el primero.</div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mt-1">
                    @foreach (var p in productos)
                    {
                        <div class="col">
                            <div class="producto-card p-3">
                                @if (!string.IsNullOrEmpty(p.Imagen))
                                {
                                    <img src="@p.Imagen" alt="@p.Nombre"
                                         style="width:100%;height:110px;object-fit:cover;border-radius:8px;margin-bottom:.75rem;" />
                                }
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <h6 class="mb-0">@p.Nombre</h6>
                                    <span class="badge @(p.Disponible ? "bg-success" : "bg-danger") ms-2">
                                        @(p.Disponible ? "Disponible" : "No disponible")
                                    </span>
                                </div>
                                <small class="text-muted d-block mb-2">@(p.Descripcion ?? "")</small>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="producto-precio">RD$ @p.Precio.ToString("N2")</span>
                                    <form asp-action="ToggleProducto" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input name="productoId"   type="hidden" value="@p.Id" />
                                        <input name="restauranteId" type="hidden" value="@restId" />
                                        <button type="submit"
                                                class="btn btn-sm @(p.Disponible ? "btn-outline-danger" : "btn-outline-success")"
                                                id="toggleProd_@p.Id">
                                            @(p.Disponible ? "Desactivar" : "Activar")
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@* Modal Nueva Categoría *@
<div class="modal fade" id="modalCategoria" tabindex="-1" aria-labelledby="modalCategoriaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCategoriaLabel">📂 Nueva Categoría</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarCategoria" method="post" id="formCategoria">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input name="RestauranteId" type="hidden" value="@restId" />
                    <div class="mb-3">
                        <label class="form-label">Nombre *</label>
                        <input name="Nombre" class="form-control" required placeholder="Ej: Entradas, Platos Fuertes..." id="catNombre" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <input name="Descripcion" class="form-control" placeholder="Descripción opcional" id="catDesc" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnGuardarCategoria">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Modal Nuevo Producto *@
<div class="modal fade" id="modalProducto" tabindex="-1" aria-labelledby="modalProductoLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalProductoLabel">🍕 Nuevo Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="GuardarProducto" method="post" id="formProducto">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input name="RestauranteId" type="hidden" value="@restId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Categoría *</label>
                            <select name="CategoriaId" class="form-select" required id="prodCategoria">
                                <option value="">— Seleccionar —</option>
                                @foreach (var c in categorias)
                                {
                                    <option value="@c.Id">@c.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Nombre *</label>
                            <input name="Nombre" class="form-control" required placeholder="Nombre del producto" id="prodNombre" />
                        </div>
                        <div class="col-md-12">
                            <label class="form-label">Descripción</label>
                            <input name="Descripcion" class="form-control" placeholder="Descripción del producto" id="prodDesc" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Precio (RD$) *</label>
                            <input name="Precio" type="number" step="0.01" min="0" class="form-control" required
                                   placeholder="0.00" id="prodPrecio" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">URL de Imagen</label>
                            <input name="Imagen" type="url" class="form-control" placeholder="https://..." id="prodImagen" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnGuardarProducto">Guardar Producto</button>
                </div>
            </form>
        </div>
    </div>
</div>
